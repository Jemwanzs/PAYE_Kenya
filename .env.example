# Server-side only — set these in Vercel Project Settings > Environment Variables.
# Never commit real values or paste them into chat.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PAYSTACK_SECRET_KEY=

# Optional — base URL the app is deployed at, used to build Paystack callback/
# return URLs. Falls back to Vercel's own VERCEL_URL if unset; set this
# explicitly once you're on a custom domain.
APP_URL= 
